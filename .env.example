# ====================================
# Spalla Dashboard — Environment Variables
# ====================================
# Copy to .env and fill with real values
# NEVER commit .env to git!

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Zoom
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Google Calendar
GOOGLE_CALENDAR_ID=primary
GOOGLE_SA_PATH=~/.config/google/credentials.json
# Para Docker sem volume mount (base64 do credentials.json):
# GOOGLE_SA_JSON=
# Workspace user the SA impersonates via Domain-Wide Delegation.
# Requires the SA Client ID to be authorized in admin.google.com with scope
# https://www.googleapis.com/auth/calendar. Events sairao organizados POR
# este usuario (nao pela SA) e invites virao do endereco dele.
# GCAL_IMPERSONATE=adm@allindigitalmarketing.com.br

# Evolution API (WhatsApp)
EVOLUTION_API_KEY=your-evolution-api-key

# Server
PORT=9999

# Auth (JWT)
JWT_SECRET=your-jwt-secret-min-32-chars

# Sentry
SENTRY_DSN=your-sentry-dsn

# S3 (Evolution media)
S3_ENDPOINT=your-s3-endpoint
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET=case-evolution-media
S3_REGION=us-east-1

# ClickUp (sync de calls com mentorados)
# CLICKUP_API_TOKEN=pk_...
# CLICKUP_MENTORADOS_FOLDER_ID=90117882229  # folder All In Marketing > all-in > Mentorados
# CLICKUP_SYNC_TYPES=onboarding,estrategia,apresentacao,oferta

# Cron sync Calendar -> ClickUp (segredo compartilhado com GitHub Actions)
# CRON_SECRET=<token aleatorio long, ex: openssl rand -hex 32>
