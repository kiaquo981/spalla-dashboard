{
    "hooks": {
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash /home/vscode/.claude/hooks/handoff-injector.sh"
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash /home/vscode/.claude/hooks/prompt-rules-injector.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash /home/vscode/.claude/hooks/worktree-guard.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash /home/vscode/.claude/hooks/branch-guard.sh"
                    }
                ]
            },
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash /home/vscode/.claude/hooks/spec-gate.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash /home/vscode/.claude/hooks/secret-guard.sh"
                    }
                ]
            }
        ]
    }
}