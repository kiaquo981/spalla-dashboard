# ============================================================
# Spalla Dashboard — Dev Container
# Uso: docker compose -f .devcontainer/docker-compose.dev.yml up -d
# Conectar: ssh -p 2225 vscode@localhost
# ============================================================

FROM python:3.9-slim

# --- System deps ---
ENV DEBIAN_FRONTEND=noninteractive TZ=America/Sao_Paulo LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server \
    git \
    curl \
    wget \
    jq \
    sudo \
    ca-certificates \
    gnupg \
    build-essential \
    make \
    less \
    nano \
    locales \
    xdg-utils \
    zip \
    unzip \
    && sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen && locale-gen \
    && rm -rf /var/lib/apt/lists/*

# --- Node.js 20 (needed for AI CLIs) ---
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# --- SSH config ---
RUN mkdir -p /var/run/sshd \
    && sed -i 's/#PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/#PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config \
    && sed -i 's/#PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config \
    && echo "AllowUsers vscode" >> /etc/ssh/sshd_config

# --- User vscode ---
RUN useradd -m -s /bin/bash vscode \
    && echo "vscode ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers \
    && mkdir -p /home/vscode/.ssh /home/vscode/.claude /home/vscode/.config /worktrees \
    && chmod 700 /home/vscode/.ssh \
    && chown -R vscode:vscode /home/vscode /worktrees

# --- Python deps (same as production) ---
COPY app/backend/requirements-railway.txt /tmp/requirements.txt
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r /tmp/requirements.txt \
    && rm /tmp/requirements.txt

# --- gh CLI ---
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh && rm -rf /var/lib/apt/lists/*

# --- AI Agent CLIs + Beads ---
RUN npm install -g @anthropic-ai/claude-code 2>/dev/null || true \
    && npm install -g @openai/codex 2>/dev/null || true \
    && npm install -g @google/gemini-cli 2>/dev/null || true \
    && npm install -g @beads/bd 2>/dev/null || true

# --- Entrypoint (persist env vars for SSH sessions) ---
COPY .devcontainer/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /workspace

EXPOSE 22 9999

CMD ["/entrypoint.sh"]
