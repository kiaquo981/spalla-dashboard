{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "routes": [
    {
      "src": "^/ref$",
      "dest": "/ref/index.html"
    },
    {
      "src": "^/ref/$",
      "dest": "/ref/index.html"
    },
    {
      "src": "^/(.*)\\.html$",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "continue": true
    },
    {
      "src": "^/(.*)\\.js$",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "continue": true
    },
    {
      "src": "^/(.*)\\.css$",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "continue": true
    },
    {
      "src": "^/photos/(.*)$",
      "headers": {
        "cache-control": "public, max-age=86400"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/10-APP-index.html"
    }
  ]
}
