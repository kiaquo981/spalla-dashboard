# Chatwoot Environment — Copy to .env and fill values
# Reference: https://www.chatwoot.com/docs/self-hosted/configuration/environment-variables

# === Core ===
SECRET_KEY_BASE=replace_with_output_of_rails_secret
FRONTEND_URL=https://chat.yourdomain.com
DEFAULT_LOCALE=pt_BR

# === Database ===
POSTGRES_HOST=chatwoot-postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot_production
POSTGRES_USERNAME=chatwoot
CW_POSTGRES_PASSWORD=chatwoot_secret_change_me
POSTGRES_PASSWORD=chatwoot_secret_change_me

# === Redis ===
REDIS_URL=redis://:redis_secret_change_me@chatwoot-redis:6379
CW_REDIS_PASSWORD=redis_secret_change_me

# === Email (SMTP) ===
MAILER_SENDER_EMAIL=noreply@yourdomain.com
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true

# === WhatsApp Cloud API ===
# Configure in Chatwoot UI after setup (Settings → Inboxes)

# === Storage ===
ACTIVE_STORAGE_SERVICE=local

# === Misc ===
RAILS_ENV=production
NODE_ENV=production
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
